{
  "name": "park-pro-grpc",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start:user:dev": "nest start user --watch",
    "start:gateway:dev": "nest start gateway --watch",
    "start:parking:dev": "nest start parking --watch",
    "start:booking:dev": "nest start booking --watch",
    "start:notification:dev": "nest start notification --watch",

    "start:user:debug": "nest start user --debug --watch",
    "start:gateway:debug": "nest start gateway --debug --watch",
    "start:parking:debug": "nest start parking --debug --watch",
    "start:booking:debug": "nest start booking --debug --watch",
    "start:notification:debug": "nest start notification --debug --watch",
    
    "start:user:prod": "node dist/apps/user/main",
    "start:gateway:prod": "node dist/apps/gateway/main",
    "start:parking:prod": "node dist/apps/parking/main",
    "start:booking:prod": "node dist/apps/booking/main",
    "start:notification:prod": "node dist/apps/notification/main",

    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",

    "test": "jest",
    "test:user:watch": "jest user --watch",
    "test:gateway:watch": "jest gateway --watch",
    "test:parking:watch": "jest parking --watch",
    "test:booking:watch": "jest booking --watch",
    "test:notification:watch": "jest notification --watch",

    "test:user:cov": "jest user --coverage",
    "test:gateway:cov": "jest gateway --coverage",
    "test:parking:cov": "jest parking --coverage",
    "test:booking:cov": "jest booking --coverage",
    "test:notification:cov": "jest notification --coverage",
    
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:user:e2e": "jest --config ./apps/user/test/jest-e2e.json",
    "test:gateway:e2e": "jest --config ./apps/gateway/test/jest-e2e.json",
    "test:parking:e2e": "jest --config ./apps/parking/test/jest-e2e.json",
    "test:booking:e2e": "jest --config ./apps/booking/test/jest-e2e.json",
    "test:notification:e2e": "jest --config ./apps/notification/test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^5.59.11",
    "@typescript-eslint/parser": "^5.59.11",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^4.2.1",
    "jest": "^29.5.0",
    "prettier": "^2.8.8",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  }
}